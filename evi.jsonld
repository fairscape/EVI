  {
    "@id": "https://w3id.org/EVI",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@id": "https://github.com/jniestroy"
      },
      {
        "@id": "https://github.com/mlev71"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@language": "en",
        "@value": "2020-07-27"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@id": "https://orcid.org/0000-0003-4060-7360"
      },
      {
        "@id": "https://orcid.org/0000-0003-4647-3877"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Evidence Graph ontology extends core concepts from the W3C Provenance Ontology PROV-O and Bioschemas' Profiles to describe evidence for correctness of findings in biomedical publications. The semantic data model in EVI is expressed using OWL2 Web Ontology Language (OWL2)."
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "http://creativecommons.org/licenses/by-nc-sa/2.0/"
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@language": "en",
        "@value": "2025-12-05"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "EVI: Evidence Graph Ontology"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespacePrefix": [
      {
        "@value": "evi"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespaceUri": [
      {
        "@id": "http://w3id.org/EVI"
      }
    ],
    "http://www.w3.org/2002/07/owl#priorVersion": [
      {
        "@language": "en",
        "@value": "1.2"
      }
    ],
