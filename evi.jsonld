    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A container is a digital object that can be defined as packages of software. Instances of containers are accompanied by all necessary dependencies such as specific versions, runtime environment and required libraries for execution."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
